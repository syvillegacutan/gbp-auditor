{
  "manifest_version": 3,
  "name": "GBP Auditor",
  "version": "1.0.0",
  "description": "Internal agency tool — Google Business Profile audit and competitor gap analysis",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://www.google.com/maps/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
